# ─── GlitchTip Stack Configuration ───────────────────────────────────────────
# See compose.yaml for service definitions.
# ─────────────────────────────────────────────────────────────────────────────

# GlitchTip image version (pin for reproducibility)
GLITCHTIP_VERSION=v4.1

# Host port for the GlitchTip web UI + API
GLITCHTIP_PORT=5004

# Secret key for session signing (generate with: python -c "import secrets; print(secrets.token_urlsafe(50))")
SECRET_KEY=<CHANGE_ME>

# Default admin / first-user email
GLITCHTIP_DOMAIN=http://localhost:5004
DEFAULT_FROM_EMAIL=glitchtip@example.com

# ��── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_USER=glitchtip
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=glitchtip
DATABASE_URL=postgres://glitchtip:<CHANGE_ME>@postgres:5432/glitchtip

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── Email (SMTP — optional) ────────────────────────────────────────────────
# EMAIL_URL=smtp+tls://user:password@smtp.example.com:587
# SERVER_EMAIL=glitchtip@example.com

# ─── Data Retention ─────────────────────────────────────────────────────────
# Auto-delete events older than N days (0 = keep forever)
GLITCHTIP_MAX_EVENT_LIFE_DAYS=90

# ─── Performance ─────────────────────────────────────────────────────────────
# Number of Celery worker processes
CELERY_WORKER_CONCURRENCY=2

# ─── OIDC Authentication (Cloudflare Access) ────────────────────────────────
# Set to true and fill in the values below, then run:
#   /opt/stacks/glitchtip/setup-oidc.sh
# Callback URL to register in Cloudflare Access:
#   {GLITCHTIP_DOMAIN}/accounts/oidc/{OIDC_PROVIDER_ID}/login/callback/
OIDC_ENABLED=false
# OIDC_PROVIDER_NAME=Cloudflare Access
# OIDC_PROVIDER_ID=cloudflare-access
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_SERVER_URL=
# OIDC_PKCE=true
