# ─── Kroki Stack Configuration ───────────────────────────────────────────────
# See compose.yaml for service definitions.
# ─────────────────────────────────────────────────────────────────────────────

# Kroki image version (pin for reproducibility)
# All images: kroki, kroki-mermaid, kroki-bpmn, kroki-excalidraw
KROKI_VERSION=0.30.1

# Server listen address (KROKI_PORT is deprecated)
KROKI_LISTEN=0.0.0.0:8000

# Safe mode: "secure" prevents PlantUML !include directives (recommended)
# Options: secure, safe, unsafe
KROKI_SAFE_MODE=secure

# Max time for external binary rendering (GraphViz, D2, etc.)
KROKI_COMMAND_TIMEOUT=30s

# Max time for Java library conversions (PlantUML, C4, etc.)
KROKI_CONVERT_TIMEOUT=60s

# Max URI length for GET requests (bytes)
KROKI_MAX_URI_LENGTH=4096
