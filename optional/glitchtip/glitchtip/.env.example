# GlitchTip application secret key (generate with: python -c "import secrets; print(secrets.token_hex(32))")
SECRET_KEY=

# Public URL used for links in emails and DSN generation
GLITCHTIP_DOMAIN=https://glitchtip.example.com

# Sender address for outbound emails
DEFAULT_FROM_EMAIL=noreply@example.com

# Email backend (consolemail:// disables real sending)
EMAIL_URL=consolemail://

# Enable Django admin panel at /admin/
ENABLE_ADMIN=False

# Enable OpenAPI docs at /api/docs/
ENABLE_OPENAPI=True

# Allow new user self-registration
ENABLE_USER_REGISTRATION=False

# Initial superuser credentials (used with manage.py createsuperuser --noinput)
DJANGO_SUPERUSER_EMAIL=admin@example.com
DJANGO_SUPERUSER_PASSWORD=CHANGEme

# --- OIDC Authentication (Cloudflare Access) ---
# Set to true and fill in the values below, then run:
#   /opt/stacks/glitchtip/setup-oidc.sh
# Callback URL to register in Cloudflare Access:
#   {GLITCHTIP_DOMAIN}/accounts/oidc/{OIDC_PROVIDER_ID}/login/callback/
OIDC_ENABLED=false
# Display name shown on the login page
# OIDC_PROVIDER_NAME=Cloudflare Access
# Machine name used in callback URL path
# OIDC_PROVIDER_ID=cloudflare-access
# OAuth2 client ID from Cloudflare Access application
# OIDC_CLIENT_ID=
# OAuth2 client secret from Cloudflare Access application
# OIDC_CLIENT_SECRET=
# OIDC discovery URL (Cloudflare Access format: https://<team>.cloudflareaccess.com/cdn-cgi/access/sso/oidc/<app-audience-tag>/.well-known/openid-configuration)
# OIDC_SERVER_URL=
# Enable PKCE (Proof Key for Code Exchange) — recommended for Cloudflare Access
# OIDC_PKCE=true
