#!/usr/bin/env bash

# ���── GitLab Server Hook: Block File Extensions ──────────────────────────────
# Rejects pushes containing files with blocked extensions (binaries, archives,
# compiled artifacts, etc.). Keeps repositories clean.
#
# Install (global, all repos):
#   mkdir -p /opt/gitlab/embedded/service/gitlab-rails/custom_hooks/pre-receive.d
#   cp block-file-extensions /opt/gitlab/embedded/service/gitlab-rails/custom_hooks/pre-receive.d/
#   chmod +x /opt/gitlab/embedded/service/gitlab-rails/custom_hooks/pre-receive.d/block-file-extensions
#
# GitLab docs: https://docs.gitlab.com/administration/server_hooks.html
# ─────────────────────────────────────────────────────────────────────────────

# Blocked extensions (case-insensitive matching, edit as needed)
BLOCKED_EXTENSIONS=(
  # Executables / compiled
  ".exe" ".dll" ".so" ".dylib" ".bin" ".com" ".msi" ".app"
  # Java / JVM
  ".jar" ".war" ".ear" ".class"
  # Archives
  ".zip" ".tar.gz" ".tgz" ".tar.bz2" ".tar.xz" ".rar" ".7z"
  # Disk images
  ".iso" ".img" ".dmg" ".vmdk" ".ova"
  # Package manager artifacts
  ".deb" ".rpm" ".apk" ".gem" ".nupkg" ".whl"
  # Database dumps
  ".sql.gz" ".sql.bz2" ".dump"
  # Secrets (common accidents)
  ".pem" ".p12" ".pfx" ".key" ".keystore" ".jks"
)

# Zero SHA used for branch deletions and new branches
ZERO_SHA="0000000000000000000000000000000000000000"

EXIT_CODE=0

while read -r old_sha new_sha ref; do
  # Skip branch/tag deletions
  if [[ "${new_sha}" == "${ZERO_SHA}" ]]; then
    continue
  fi

  # Determine diff range
  if [[ "${old_sha}" == "${ZERO_SHA}" ]]; then
    # New branch: check all files in the push
    DIFF_RANGE="${new_sha}"
    FILES=$(git log --diff-filter=ACR --name-only --pretty=format: "${DIFF_RANGE}" --not --remotes 2>/dev/null | sort -u)
    if [[ -z "${FILES}" ]]; then
      # Fallback: list all files at the new ref
      FILES=$(git ls-tree -r --name-only "${new_sha}" 2>/dev/null)
    fi
  else
    # Existing branch: only check new/changed files
    FILES=$(git diff --diff-filter=ACR --name-only "${old_sha}" "${new_sha}" 2>/dev/null)
  fi

  if [[ -z "${FILES}" ]]; then
    continue
  fi

  BLOCKED_FILES=()

  while IFS= read -r file; do
    [[ -z "${file}" ]] && continue
    LOWER_FILE=$(printf '%s' "${file}" | tr '[:upper:]' '[:lower:]')

    for ext in "${BLOCKED_EXTENSIONS[@]}"; do
      if [[ "${LOWER_FILE}" == *"${ext}" ]]; then
        BLOCKED_FILES+=("${file} (${ext})")
        break
      fi
    done
  done <<< "${FILES}"

  if [[ ${#BLOCKED_FILES[@]} -gt 0 ]]; then
    printf '\n' >&2
    printf '  ========================================\n' >&2
    printf '  PUSH REJECTED: blocked file type(s)\n' >&2
    printf '  ========================================\n' >&2
    printf '\n' >&2
    printf '  Ref: %s\n' "${ref}" >&2
    printf '\n' >&2
    printf '  The following files have blocked extensions:\n' >&2
    for blocked in "${BLOCKED_FILES[@]}"; do
      printf '    - %s\n' "${blocked}" >&2
    done
    printf '\n' >&2
    printf '  These file types should not be committed:\n' >&2
    printf '    - Use .gitignore to exclude build artifacts\n' >&2
    printf '    - Use GitLab Packages or R2 for binary releases\n' >&2
    printf '    - Use CI/CD artifacts for build outputs\n' >&2
    printf '  ========================================\n' >&2
    printf '\n' >&2
    EXIT_CODE=1
  fi
done

exit "${EXIT_CODE}"
