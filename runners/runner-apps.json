{
  "$schema": "runner-apps-schema",
  "description": "Tools and packages required on the GitLab Runner LXC for CI/CD jobs.",

  "apt": {
    "description": "Packages installed via apt-get.",
    "packages": [
      {
        "name": "build-essential",
        "description": "GCC, G++, make — native compilation"
      },
      {
        "name": "ca-certificates",
        "description": "TLS/SSL certificate authority bundle"
      },
      { "name": "curl", "description": "HTTP client" },
      { "name": "wget", "description": "HTTP client (alt)" },
      { "name": "jq", "description": "JSON processor for CI scripts" },
      { "name": "unzip", "description": "Archive extraction" },
      { "name": "zip", "description": "Archive creation" },
      {
        "name": "git",
        "description": "Version control (also installed by GitLab, but ensures latest)"
      },
      { "name": "gnupg", "description": "GPG signing and verification" },
      { "name": "make", "description": "Build automation tool" },
      { "name": "mc", "description": "Midnight Commander file manager" },
      { "name": "nano", "description": "Text editor" },
      { "name": "patch", "description": "Apply patches to files" },
      { "name": "shellcheck", "description": "Shell script linter" },
      { "name": "python3", "description": "Python runtime" },
      { "name": "python3-pip", "description": "Python package manager" },
      { "name": "python3-dev", "description": "Python C extension headers" },
      {
        "name": "python3-yaml",
        "description": "YAML parsing for scripts (sync-certs, etc.)"
      },
      { "name": "rsync", "description": "File sync for deployments" },
      { "name": "sudo", "description": "Privilege escalation" },
      {
        "name": "ssh",
        "description": "Secure shell client and server (metapackage)"
      },
      { "name": "tree", "description": "Directory listing for debug output" },
      { "name": "htop", "description": "System monitoring" },
      {
        "name": "screen",
        "description": "Terminal multiplexer for background tasks"
      },
      {
        "name": "postfix",
        "description": "Mail transfer agent for CI notifications"
      },
      { "name": "nftables", "description": "Packet filtering framework" },
      { "name": "ufw", "description": "Uncomplicated firewall" },
      { "name": "bats", "description": "Bash Automated Testing System" },
      { "name": "bats-assert", "description": "Bats assertion library" },
      { "name": "bats-file", "description": "Bats file-system assertions" },
      { "name": "bats-support", "description": "Bats support library" },
      {
        "name": "parallel",
        "description": "GNU parallel for concurrent CI tasks"
      }
    ]
  },

  "gitlab_runner": {
    "description": "GitLab Runner and helper images installed from the official GitLab repo.",
    "packages": [
      {
        "name": "gitlab-runner",
        "description": "GitLab CI/CD job executor",
        "version": "18.9.0"
      },
      {
        "name": "gitlab-runner-helper-images",
        "description": "Pre-built helper images for runner jobs"
      }
    ]
  },

  "docker": {
    "description": "Docker CE + plugins. The gitlab-runner user is added to the docker group.",
    "packages": [
      { "name": "docker-ce", "description": "Docker engine" },
      { "name": "docker-ce-cli", "description": "Docker CLI" },
      { "name": "containerd.io", "description": "Container runtime" },
      {
        "name": "docker-buildx-plugin",
        "description": "Multi-platform builds"
      },
      { "name": "docker-compose-plugin", "description": "Docker Compose v2" }
    ],
    "post_install": "usermod -aG docker gitlab-runner"
  },

  "iac": {
    "description": "Infrastructure-as-Code tools installed via apt repos.",
    "packages": [
      {
        "name": "terraform",
        "description": "HashiCorp IaC provisioning tool",
        "version": "1.14.6"
      },
      {
        "name": "tofu",
        "description": "OpenTofu — open-source Terraform alternative",
        "version": "1.11.5"
      }
    ]
  },

  "node": {
    "description": "Node.js LTS via NodeSource. Installed system-wide.",
    "version": "22",
    "method": "nodesource",
    "packages": [{ "name": "nodejs", "description": "Node.js runtime + npm" }]
  },

  "npm_global": {
    "description": "Global npm packages available to CI jobs.",
    "packages": [
      { "name": "pnpm", "description": "Fast, disk-efficient package manager" },
      {
        "name": "wrangler",
        "description": "Cloudflare Workers CLI (includes miniflare)"
      },
      { "name": "prettier", "description": "Code formatter" },
      { "name": "eslint", "description": "JavaScript/TypeScript linter" },
      { "name": "@eslint/js", "description": "ESLint core JS config" },
      { "name": "markdownlint-cli", "description": "Markdown linter CLI" },
      {
        "name": "markdownlint-cli2",
        "description": "Structural Markdown linter"
      },
      {
        "name": "markdownlint-cli2-formatter-junit",
        "description": "JUnit report formatter for markdownlint-cli2"
      },
      {
        "name": "markdownlint-cli2-formatter-codequality",
        "description": "Code Quality report formatter for markdownlint-cli2"
      },
      { "name": "jsonlint-cli", "description": "JSON linter/validator" },
      {
        "name": "git-cliff",
        "description": "Changelog generator from Conventional Commits"
      },
      {
        "name": "obsidian-headless",
        "description": "Headless Obsidian CLI for vault operations"
      }
    ]
  },

  "pip": {
    "description": "Python packages installed via pip3.",
    "packages": [
      {
        "name": "codespell",
        "description": "Typo detection for code and docs"
      },
      { "name": "PyYAML", "description": "YAML parser for Python scripts" },
      {
        "name": "semgrep",
        "description": "Static analysis / SAST scanner",
        "version": "1.154.0"
      },
      { "name": "yamllint", "description": "YAML linter" },
      { "name": "pytest", "description": "Python test framework" },
      {
        "name": "ruamel.yaml",
        "description": "YAML parser with round-trip support"
      },
      {
        "name": "ansible-core",
        "description": "Ansible automation engine"
      },
      {
        "name": "ansible-lint",
        "description": "Ansible playbook linter"
      },
      { "name": "black", "description": "Python code formatter" },
      { "name": "isort", "description": "Python import sorter" },
      { "name": "mypy", "description": "Python static type checker" },
      { "name": "ruff", "description": "Fast Python linter and formatter" },
      {
        "name": "python-dotenv",
        "description": "Load environment variables from .env files"
      }
    ]
  },

  "binary": {
    "description": "Standalone binaries installed to /usr/local/bin.",
    "packages": [
      {
        "name": "shfmt",
        "description": "Shell script formatter (Go binary from GitHub releases)",
        "version": "3.13.0",
        "url": "https://github.com/mvdan/sh/releases"
      },
      {
        "name": "release-cli",
        "description": "GitLab release creation tool (required by release: keyword in CI)",
        "version": "0.24.0",
        "url": "https://gitlab.com/gitlab-org/release-cli"
      },
      {
        "name": "gitleaks",
        "description": "Secret detection scanner",
        "version": "8.30.0",
        "url": "https://github.com/gitleaks/gitleaks/releases"
      },
      {
        "name": "hadolint",
        "description": "Dockerfile linter",
        "version": "2.14.0",
        "url": "https://github.com/hadolint/hadolint/releases"
      },
      {
        "name": "tflint",
        "description": "Terraform linter",
        "version": "0.61.0",
        "url": "https://github.com/terraform-linters/tflint/releases"
      },
      {
        "name": "tfsec",
        "description": "Terraform security scanner (deprecated — migrating to Trivy)",
        "version": "1.28.14",
        "url": "https://github.com/aquasecurity/tfsec/releases"
      },
      {
        "name": "taplo",
        "description": "TOML formatter and linter",
        "version": "0.10.0",
        "url": "https://github.com/tamasfe/taplo/releases"
      }
    ]
  },

  "scripts": {
    "description": "Custom helper scripts installed to /usr/local/bin for CI report conversion. Source files live in runners/scripts/.",
    "install_dir": "/usr/local/bin",
    "source_dir": "scripts",
    "packages": [
      {
        "name": "gitleaks-to-codequality",
        "description": "Converts gitleaks JSON to GitLab Code Quality format",
        "source": "scripts/gitleaks-to-codequality"
      },
      {
        "name": "shellcheck-to-junit",
        "description": "Converts shellcheck JSON to JUnit XML",
        "source": "scripts/shellcheck-to-junit"
      },
      {
        "name": "shellcheck-to-codequality",
        "description": "Converts shellcheck JSON to GitLab Code Quality format",
        "source": "scripts/shellcheck-to-codequality"
      },
      {
        "name": "markdownlint-junit-config",
        "description": "Ensures markdownlint-cli2 JUnit and Code Quality formatters are configured",
        "source": "scripts/markdownlint-junit-config"
      },
      {
        "name": "semgrep-to-codequality",
        "description": "Converts semgrep JSON to GitLab Code Quality format",
        "source": "scripts/semgrep-to-codequality"
      },
      {
        "name": "tflint-to-codequality",
        "description": "Converts tflint JSON to GitLab Code Quality format",
        "source": "scripts/tflint-to-codequality"
      }
    ]
  }
}
