# =============================================================================
# GitLab Runner Container -- Provisioning Configuration
# =============================================================================
# One-shot config for gitlab-runner-container.sh
# All images, packages, and GPG keys are pinned by hash for reproducibility.
#
# Copy to gitlab-runner-container.env and fill in secrets before running.
# =============================================================================

# ─── Container Identity ─────────────────────────────────────────────────────
CTID=99997
HOSTNAME=gitlab-runner-2
PASSWORD="GitLabRunner-ChangeMe"

# ─── Resources ──────────────────────────────────────────────────────────────
CORES=8
MEMORY=8192
SWAP=0
DISK_SIZE=40

# ─── Network ────────────────────────────────────────────────────────────────
# NET_ID: Proxmox network device identifier (default: net0)
#NET_ID=net0
# NET_NAME: Interface name inside the container (default: eth0)
#NET_NAME=eth0
# BRIDGE: Proxmox bridge to attach to (default: vmbr1)
BRIDGE=vmbr1
IP=10.1.1.102/24
GATEWAY=10.1.1.254
MTU=9000
VLAN=1111
NAMESERVER=10.1.1.254
SEARCHDOMAIN=lab.example.com

# ─── Container Settings ─────────────────────────────────────────────────────
UNPRIVILEGED=1
ONBOOT=1
TIMEZONE=America/New_York
FEATURES=nesting=1,keyctl=1,fuse=1

# Proxmox UI tags (semicolon-separated, visible in the Proxmox web UI)
PCT_TAGS="runner;gitlab"

# ─── Template (pinned) ──────────────────────────────────────────────────────
TEMPLATE=debian-13-standard_13.1-2_amd64.tar.zst
TEMPLATE_STORAGE=local
TEMPLATE_SHA256=ca6dffb91c3239fedc30af2c11389198140de1f1fc3d58082f3d9f4239b92e1b

# ─── Storage ────────────────────────────────────────────────────────────────
CONTAINER_STORAGE=local-zfs

# ─── Locale ─────────────────────────────────────────────────────────────────
FIX_LOCALE=true

# ─── Docker (pinned versions + GPG key hash) ────────────────────────────────
ENABLE_DOCKER=true
DOCKER_GPG_SHA256=1500c1f56fa9e26b9b8f42452a553675796ade0807cdce11975eb98170b3a570
DOCKER_CE_VERSION=5:29.2.1-1~debian.13~trixie
DOCKER_CE_CLI_VERSION=5:29.2.1-1~debian.13~trixie
CONTAINERD_VERSION=2.2.1-1~debian.13~trixie
DOCKER_BUILDX_VERSION=0.31.1-1~debian.13~trixie
DOCKER_COMPOSE_VERSION=5.1.0-1~debian.13~trixie

# Docker daemon MTU (match your LXC/network MTU for jumbo frames)
DOCKER_MTU=9000

# ─── Dockge (pinned image digest) ───────────────────────────────────────────
ENABLE_DOCKGE=true
DOCKGE_PORT=5001
DOCKGE_IMAGE_DIGEST=sha256:335c6368b880ecc203236ed89e6e5232e0d6578e8ef5920e4a502390451502bf

# ─── SSH Keys ────────────────────────────────────────────────────────────────
# Keys are loaded from sshkeys.txt (one public key per line).
# Override the path with SSH_KEYS_FILE if needed.
#SSH_KEYS_FILE=sshkeys.txt

# ─── GitLab Runner ──────────────────────────────────────────────────────────
ENABLE_RUNNER=true
ENABLE_METRICS=true
GITLAB_URL=https://gitlab.example.com
GITLAB_PAT="<YOUR_GITLAB_PERSONAL_ACCESS_TOKEN>"
GITLAB_RUNNER_EXECUTOR=shell

# Runner scope: instance_type (shared, all projects), group_type (needs
# GITLAB_RUNNER_GROUP_ID), or project_type (needs GITLAB_RUNNER_PROJECT_ID)
GITLAB_RUNNER_TYPE=instance_type
#GITLAB_RUNNER_GROUP_ID=
#GITLAB_RUNNER_PROJECT_ID=

# Tags for job routing (comma-separated). Jobs with matching tags will be
# picked up by this runner. Leave empty for no tag filtering.
GITLAB_RUNNER_TAGS=docker,linux,shell

# Whether this runner picks up jobs that have no tags defined.
# Set to false when using tags for routing (recommended).
GITLAB_RUNNER_RUN_UNTAGGED=false
GITLAB_RUNNER_CONCURRENT=2
GITLAB_RUNNER_LIMIT=1
GITLAB_RUNNER_OUTPUT_LIMIT=8192
GITLAB_RUNNER_REQUEST_CONCURRENCY=1

# Runner service resource limits (systemd)
RUNNER_CPU_QUOTA=600%
RUNNER_MEMORY_MAX=6G

# ─── GitLab Runner APT Repo (pinned) ────────────────────────────────────────
GITLAB_RUNNER_GPG_SHA256=b4cbeb03de41e82bb5d1bf80875372a4f467e5555a53f66dc55d981224d08bba
GITLAB_RUNNER_VERSION=18.9.0-1

# ─── Node.js (pinned) ───────────────────────────────────────────────────────
ENABLE_NODEJS=true
NODESOURCE_GPG_SHA256=7a96b125f721c99e07d3f45b279adbd6884ec4f3f06750f6b54df40cfae36836
NODEJS_VERSION=22.22.0-1nodesource1

# ─── Terraform (pinned) ─────────────────────────────────────────────────────
ENABLE_TERRAFORM=true
HASHICORP_GPG_SHA256=801d1c66a9076c9990fac4bcf90f649e273cb36c6a212981b145404fcdb57ad1
TERRAFORM_VERSION=1.14.6-1

# ─── OpenTofu (pinned) ──────────────────────────────────────────────────────
ENABLE_OPENTOFU=true
OPENTOFU_GPG_SHA256=55fcff8ee506ffc46a37a70af5b76b4181f2f5e24b18387013a8629144c02fdf
OPENTOFU_REPO_GPG_SHA256=6e86716e9fea4cf86a7faf610088cbb185c0d1cf98a4cb693a298bb9d52acf0b
TOFU_VERSION=1.11.5

# ─── Build Tools (pinned) ───────────────────────────────────────────────────
ENABLE_BUILD_TOOLS=true
# build-essential, python3-dev, python3-pip not version-pinned (distro packages)

# ─── NPM Globals (pinned versions) ──────────────────────────────────────────
NPM_GLOBALS="eslint@10.0.2 @eslint/js@10.0.1 prettier@3.8.1 markdownlint-cli@0.47.0 markdownlint-cli2@0.21.0 markdownlint-cli2-formatter-junit@0.0.14 jsonlint-cli@1.0.1 git-cliff@2.12.0 pnpm@10.30.3 wrangler@4.69.0"

# ─── Pip Packages (pinned versions) ─────────────────────────────────────────
PIP_PACKAGES="codespell==2.4.1 PyYAML==6.0.3"

# ─── Sysctl Tuning ──────────────────────────────────────────────────────────
# Node.js file watchers need higher inotify limits
SYSCTL_INOTIFY_MAX_USER_INSTANCES=65536
SYSCTL_INOTIFY_MAX_USER_WATCHES=4194304
SYSCTL_INOTIFY_MAX_QUEUED_EVENTS=8388608

# ─── Health Check Endpoint ────────────────────────────────────────────────────
# Lightweight /health JSON endpoint via systemd socket activation (zero idle cost).
# Reports status of Docker, gitlab-runner, and all running containers.
HEALTH_PORT=5000

# ─── UFW Firewall ────────────────────────────────────────────────────────────
ENABLE_UFW=true
# Allow SSH, health, and Dockge from this CIDR (covers 10.0.0.0 - 10.255.255.255)
UFW_ALLOW_FROM=10.0.0.0/8
# Inbound ports to allow from UFW_ALLOW_FROM (space-separated)
UFW_INBOUND_PORTS="22 5000 5001 5002"

# ─── Additional Stacks ──────────────────────────────────────────────────────
# Directory containing stack subdirectories to deploy into Dockge.
# Each subdirectory should have a compose.yaml (and optional .env).
# Defaults to ./stacks next to this script.
#STACKS_DIR=./stacks

# ─── Kroki (optional) ───────────────────────────────────────────────────────
# Diagram-as-code renderer. Enable by placing a kroki stack in STACKS_DIR.
# GitLab integration: Admin > Settings > General > Kroki
#   URL: http://<container-ip>:<KROKI_PORT>
#
# These variables are used by the kroki compose.yaml, not the script itself.
# All images pinned by digest for supply-chain safety.
#KROKI_PORT=5003
#KROKI_IMAGE=yuzutech/kroki@sha256:4cfb9d48a1d9e18c346d505fd85c9ad16121d1691602b0e580db904b00c04320
#KROKI_MERMAID_IMAGE=yuzutech/kroki-mermaid@sha256:2216fa675936bbc47c984aecb867dd995561d6e8e1bc20ad3d87c473bb26ce6d
#KROKI_BPMN_IMAGE=yuzutech/kroki-bpmn@sha256:a3d579ac0f4b432250471fd37deefe8e2f78d08b5e888e3545872fcb2dc88e99
#KROKI_EXCALIDRAW_IMAGE=yuzutech/kroki-excalidraw@sha256:091441d2fc45e8ec9ab3a65ac98fff0d73ae1d355652bebd3d2cc21ed8efd3f2
#KROKI_SAFE_MODE=secure
#KROKI_COMMAND_TIMEOUT=30s
#KROKI_CONVERT_TIMEOUT=60s
#KROKI_MAX_URI_LENGTH=4096
