#!/usr/bin/env python3
"""Ensure markdownlint-cli2 JUnit and Code Quality formatters are configured.

Checks for .markdownlint-cli2.jsonc and adds the JUnit and Code Quality
formatters if not already present. Creates the file if it does not exist.

Usage:
    markdownlint-junit-config [junit-output] [codequality-output]

Defaults: markdownlint.xml, gl-codequality-markdownlint.json
"""

import json
import sys
from pathlib import Path

CONFIG = ".markdownlint-cli2.jsonc"

FORMATTERS = [
    ("markdownlint-cli2-formatter-junit", "markdownlint.xml"),
    ("markdownlint-cli2-formatter-codequality", "gl-codequality-markdownlint.json"),
]


def main():
    junit_name = sys.argv[1] if len(sys.argv) > 1 else FORMATTERS[0][1]
    codequality_name = sys.argv[2] if len(sys.argv) > 2 else FORMATTERS[1][1]

    config_path = Path(CONFIG)

    if config_path.exists():
        with open(config_path) as f:
            try:
                data = json.load(f)
            except json.JSONDecodeError:
                data = {}
    else:
        data = {}

    formatters = data.get("outputFormatters", [])

    desired = [
        (FORMATTERS[0][0], junit_name),
        (FORMATTERS[1][0], codequality_name),
    ]

    for fmt_name, output_name in desired:
        already = any(
            isinstance(f, list) and len(f) > 0 and f[0] == fmt_name
            for f in formatters
        )
        if not already:
            formatters.append([fmt_name, {"name": output_name}])

    data["outputFormatters"] = formatters

    with open(config_path, "w") as f:
        json.dump(data, f, indent=2)
        f.write("\n")


if __name__ == "__main__":
    main()
