#!/usr/bin/env python3
"""Convert shellcheck JSON output to GitLab Code Quality (CodeClimate) format.

Usage:
    shellcheck --format=json *.sh > raw.json
    shellcheck-to-codequality raw.json > gl-codequality-shellcheck.json
    cat raw.json | shellcheck-to-codequality > gl-codequality-shellcheck.json
"""

import hashlib
import json
import sys

SEVERITY_MAP = {
    "error": "critical",
    "warning": "major",
    "info": "minor",
    "style": "minor",
}


def convert(shellcheck_data):
    """Convert shellcheck JSON to CodeClimate format."""
    issues = []

    for finding in shellcheck_data:
        code = finding.get("code", 0)
        level = finding.get("level", "warning")
        message = finding.get("message", "ShellCheck finding")
        file_path = finding.get("file", "unknown")
        start_line = finding.get("line", 1)
        severity = SEVERITY_MAP.get(level, "major")

        fingerprint = hashlib.md5(
            f"SC{code}:{file_path}:{start_line}".encode()
        ).hexdigest()

        issues.append(
            {
                "type": "issue",
                "check_name": f"shellcheck/SC{code}",
                "description": f"SC{code}: {message}",
                "categories": ["Bug Risk"],
                "severity": severity,
                "fingerprint": fingerprint,
                "location": {
                    "path": file_path,
                    "lines": {"begin": start_line},
                },
            }
        )

    return issues


def main():
    if len(sys.argv) > 1 and sys.argv[1] != "-":
        with open(sys.argv[1]) as f:
            try:
                data = json.load(f)
            except Exception:
                data = []
    else:
        data = json.load(sys.stdin)

    result = convert(data)
    json.dump(result, sys.stdout, indent=2)
    sys.stdout.write("\n")


if __name__ == "__main__":
    main()
