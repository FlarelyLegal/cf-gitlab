# ─── Target ───────────────────────────────────────────────────────────────────
# SSH destination for the GitLab LXC — can be an IP or an SSH config host alias.
# Local network:  LXC_HOST="root@<LXC_IP>"
# Via CF Tunnel:  LXC_HOST="<SSH_CONFIG_ALIAS>"
LXC_HOST="root@<LXC_IP>"

# ─── GitLab Core ──────────────────────────────────────────────────────────────
GITLAB_DOMAIN="gitlab.example.com"
GITLAB_ROOT_EMAIL="admin@example.com"
GITLAB_ROOT_PASSWORD="<STRONG_PASSWORD>"
ORG_NAME="Example"
ORG_URL="https://example.com"

# ─── TLS / Cloudflare ────────────────────────────────────────────────────────
CF_API_TOKEN="<YOUR_CF_API_TOKEN>"
CERT_EMAIL="admin@example.com"

# ─── CDN (optional — only needed for cloudflare/ scripts and gitlab-cdn/) ─
CF_ZONE_ID="<YOUR_CF_ZONE_ID>"
CDN_DOMAIN="cdn.gitlab.example.com"
CDN_WORKER_NAME="cdn-gitlab"
VPC_SERVICE_ID="<VPC_SERVICE_ID>"

# ─── Subdomains ───────────────────────────────────────────────────────────────
REGISTRY_DOMAIN="registry.gitlab.example.com"
PAGES_DOMAIN="pages.example.com"

# ─── Networking ───────────────────────────────────────────────────────────────
INTERNAL_DNS="10.0.0.1"
SSH_ALLOW_CIDR="10.0.0.0/8"

# ─── System ───────────────────────────────────────────────────────────────────
TZ="America/New_York"

# ─── OmniAuth: Cloudflare Access OIDC ────────────────────────────────────────
OIDC_ISSUER="https://<TEAM>.cloudflareaccess.com/cdn-cgi/access/sso/oidc/<APP_ID>"
OIDC_CLIENT_ID="<CF_ACCESS_APP_ID>"
OIDC_CLIENT_SECRET="<CF_ACCESS_APP_SECRET>"

# ─── OmniAuth: GitHub (for imports) ──────────────────────────────────────────
GITHUB_APP_ID="<GITHUB_OAUTH_APP_ID>"
GITHUB_APP_SECRET="<GITHUB_OAUTH_APP_SECRET>"

# ─── Cloudflare R2 Object Storage ────────────────────────────────────────────
R2_ENDPOINT="https://<ACCOUNT_ID>.r2.cloudflarestorage.com"
R2_ACCESS_KEY="<R2_ACCESS_KEY_ID>"
R2_SECRET_KEY="<R2_SECRET_ACCESS_KEY>"
R2_BUCKET_PREFIX="gitlab"  # Creates buckets: gitlab-artifacts, gitlab-lfs, gitlab-uploads, etc.
R2_BACKUP_BUCKET="gitlab-backups"  # Backup archive upload bucket (DB + repos + config)

# ─── Webhook Email Notifications (optional) ──────────────────────────────────
# Set to "true" to add the send_email binding to the CDN Worker.
# Requires Email Routing enabled on the zone + verified destination addresses.
# After deploying, set secrets: WEBHOOK_SECRET, WEBHOOK_RECIPIENT, WEBHOOK_FROM, WEBHOOK_FROM_NAME
ENABLE_WEBHOOK_EMAIL="false"

# ─── Kroki (optional — defaults to LXC_HOST if not set) ─────────────────────
KROKI_HOST=""  # e.g., "root@10.1.1.100" — leave empty to deploy to LXC_HOST

# ─── Runner ───────────────────────────────────────────────────────────────────
RUNNER_NAME="gitlab-runner"
RUNNER_TAGS="self-hosted,linux,x64"
RUNNER_HOSTS="root@<runner-ip-1>,root@<runner-ip-2>"  # Comma-separated list for update-runners.sh
