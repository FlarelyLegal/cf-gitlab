#!/usr/bin/env bash

# ─── GitLab Server Hook: Branch Naming Convention ────────────────────────────
# Rejects pushes to branches that don't match an allowed naming pattern.
# Runs synchronously during git push (pre-receive) and blocks non-conforming
# branch names with a helpful error message.
#
# Allowed patterns:
#   feature/*  fix/*  hotfix/*  release/*  chore/*  docs/*
#
# Exempt branches (direct push allowed):
#   main, master
#
# Install (global, all repos):
#   mkdir -p /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d
#   cp enforce-branch-naming /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d/
#   chmod +x /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d/enforce-branch-naming
#   chown git:git /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d/enforce-branch-naming
#
# GitLab docs: https://docs.gitlab.com/administration/server_hooks.html
# ─────────────────────────────────────────────────────────────────────────────

# Allowed prefixes (edit this list to add/remove conventions)
ALLOWED_PREFIXES=(
  "feature/"
  "fix/"
  "hotfix/"
  "release/"
  "chore/"
  "docs/"
)

# Branches exempt from naming rules (exact match)
EXEMPT_BRANCHES=(
  "main"
  "master"
)

EXIT_CODE=0

while read -r _old_sha NEW_SHA REF; do
  # Skip tag pushes
  if [[ "${REF}" != refs/heads/* ]]; then
    continue
  fi

  # Skip branch deletions (new sha is all zeros)
  if [[ "${NEW_SHA}" =~ ^0+$ ]]; then
    continue
  fi

  BRANCH="${REF#refs/heads/}"

  # Check exempt list
  EXEMPT=false
  for exempt in "${EXEMPT_BRANCHES[@]}"; do
    if [[ "${BRANCH}" == "${exempt}" ]]; then
      EXEMPT=true
      break
    fi
  done
  if ${EXEMPT}; then
    continue
  fi

  # Check against allowed prefixes
  VALID=false
  for prefix in "${ALLOWED_PREFIXES[@]}"; do
    if [[ "${BRANCH}" == "${prefix}"* ]]; then
      VALID=true
      break
    fi
  done

  if ! ${VALID}; then
    printf '\n' >&2
    printf '  ========================================\n' >&2
    printf '  PUSH REJECTED: invalid branch name\n' >&2
    printf '  ========================================\n' >&2
    printf '\n' >&2
    printf '  Branch: %s\n' "${BRANCH}" >&2
    printf '\n' >&2
    printf '  Branches must use one of these prefixes:\n' >&2
    for prefix in "${ALLOWED_PREFIXES[@]}"; do
      printf '    - %s\n' "${prefix}" >&2
    done
    printf '\n' >&2
    printf '  Examples:\n' >&2
    printf '    feature/add-login-page\n' >&2
    printf '    fix/header-alignment\n' >&2
    printf '    chore/update-deps\n' >&2
    printf '\n' >&2
    printf '  Exempt branches: %s\n' "${EXEMPT_BRANCHES[*]}" >&2
    printf '  ========================================\n' >&2
    printf '\n' >&2
    EXIT_CODE=1
  fi
done

exit "${EXIT_CODE}"
