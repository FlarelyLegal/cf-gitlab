#!/usr/bin/env bash

# ─── GitLab Server Hook: Commit Message Format ──────────────────────────────
# Rejects pushes containing commits that don't follow Conventional Commits.
# Runs synchronously during git push (pre-receive).
#
# Required format:
#   <type>[optional scope]: <description>
#
# Allowed types:
#   feat, fix, docs, style, refactor, perf, test, build, ci, chore, revert
#
# Examples:
#   feat: add user login page
#   fix(auth): resolve token expiry bug
#   docs: update README with deploy steps
#   chore!: drop Node 16 support
#
# Merge commits and reverts are always allowed.
#
# Install (global, all repos):
#   mkdir -p /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d
#   cp enforce-commit-message /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d/
#   chmod +x /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d/enforce-commit-message
#   chown git:git /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d/enforce-commit-message
#
# GitLab docs: https://docs.gitlab.com/administration/server_hooks.html
# ─────────────────────────────────────────────────────────────────────────────

# Allowed types (edit to customize)
ALLOWED_TYPES="feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert"

# Pattern: type(optional-scope)optional-!: description
# The description must start with a lowercase letter or digit
PATTERN="^(${ALLOWED_TYPES})(\([a-zA-Z0-9._-]+\))?!?: [a-z0-9]"

# Merge commit pattern (always allowed)
MERGE_PATTERN="^Merge "

# Zero SHA for branch creation/deletion
ZERO_SHA="0000000000000000000000000000000000000000"

# Skip snippet repositories (GitLab uses non-conventional messages like "Initial commit")
if [[ "${GL_REPOSITORY:-}" == snippet-* ]]; then
  exit 0
fi

EXIT_CODE=0

while read -r old_sha new_sha ref; do
  # Skip tag pushes
  if [[ "${ref}" != refs/heads/* ]]; then
    continue
  fi

  # Skip deletions
  if [[ "${new_sha}" == "${ZERO_SHA}" ]]; then
    continue
  fi

  # Determine commit range
  if [[ "${old_sha}" == "${ZERO_SHA}" ]]; then
    # New branch: check commits not reachable from any remote branch
    COMMITS=$(git rev-list "${new_sha}" --not --remotes 2>/dev/null)
  else
    COMMITS=$(git rev-list "${old_sha}..${new_sha}" 2>/dev/null)
  fi

  if [[ -z "${COMMITS}" ]]; then
    continue
  fi

  BAD_COMMITS=()

  while IFS= read -r sha; do
    [[ -z "${sha}" ]] && continue
    MSG=$(git log -1 --format='%s' "${sha}" 2>/dev/null)

    # Allow merge commits
    if [[ "${MSG}" =~ ${MERGE_PATTERN} ]]; then
      continue
    fi

    # Check against conventional commit pattern
    if [[ ! "${MSG}" =~ ${PATTERN} ]]; then
      SHORT_SHA="${sha:0:8}"
      BAD_COMMITS+=("${SHORT_SHA}  ${MSG}")
    fi
  done <<<"${COMMITS}"

  if [[ ${#BAD_COMMITS[@]} -gt 0 ]]; then
    printf '\n' >&2
    printf '  ========================================\n' >&2
    printf '  PUSH REJECTED: bad commit message(s)\n' >&2
    printf '  ========================================\n' >&2
    printf '\n' >&2
    printf '  Ref: %s\n' "${ref}" >&2
    printf '\n' >&2
    printf '  These commits do not follow Conventional Commits:\n' >&2
    for bad in "${BAD_COMMITS[@]}"; do
      printf '    %s\n' "${bad}" >&2
    done
    printf '\n' >&2
    printf '  Required format:\n' >&2
    printf '    <type>[scope]: <description>\n' >&2
    printf '\n' >&2
    printf '  Allowed types:\n' >&2
    printf '    feat fix docs style refactor perf test build ci chore revert\n' >&2
    printf '\n' >&2
    printf '  Examples:\n' >&2
    printf '    feat: add user login page\n' >&2
    printf '    fix(auth): resolve token expiry bug\n' >&2
    printf '    docs: update README with deploy steps\n' >&2
    printf '  ========================================\n' >&2
    printf '\n' >&2
    EXIT_CODE=1
  fi
done

exit "${EXIT_CODE}"
