#!/usr/bin/env bash

# ─── GitLab Server Hook: Secret / Credential Detection ──────────────────────
# Scans pushed diffs for high-confidence secret patterns (API keys, private
# keys, tokens, passwords in URLs, etc.). Rejects the push if any match.
#
# This gives GitLab CE the same protection that Premium's Secret Push
# Protection provides, at the pre-receive level.
#
# Design decisions:
#   - Scans only the diff (added lines), not the full tree
#   - Patterns are tuned for high confidence / low false positives
#   - Allowlist file (.secret-detection-allowlist) lets teams suppress
#     known false positives per-repo (one regex per line, # for comments)
#   - Skips binary files, test fixtures, and lock files
#   - All output goes to stderr (GitLab displays it to the pusher)
#
# Pattern count: 115+ rules across 50+ providers
#
# Install (global, all repos):
#   mkdir -p /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d
#   cp detect-secrets /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d/
#   chmod +x /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d/detect-secrets
#   chown git:git /var/opt/gitlab/gitaly/custom_hooks/pre-receive.d/detect-secrets
#
# Requires in gitlab.rb:
#   gitaly['configuration'] = {
#     hooks: { custom_hooks_dir: '/var/opt/gitlab/gitaly/custom_hooks' }
#   }
#
# GitLab docs: https://docs.gitlab.com/administration/server_hooks.html
# ─────────────────────────────────────────────────────────────────────────────

ZERO_SHA="0000000000000000000000000000000000000000"
# SHA of an empty tree (used as base when no other ref exists)
EMPTY_TREE="4b825dc642cb6eb9a060e54bf899d15363da7b23"
EXIT_CODE=0

# ─── Secret patterns ────────────────────────────────────────────────────────
# Each entry: "Label:::regex"
# Regex is matched against added lines in the diff (grep -E -e).
# Only high-confidence patterns with unique prefixes or structure.
# Organized by provider for maintainability.
SECRET_PATTERNS=(

  # ─── Private keys (PEM-encoded) ───────────────────────────────────────────
  "RSA private key:::-----BEGIN RSA PRIVATE KEY-----"
  "DSA private key:::-----BEGIN DSA PRIVATE KEY-----"
  "EC private key:::-----BEGIN EC PRIVATE KEY-----"
  "OpenSSH private key:::-----BEGIN OPENSSH PRIVATE KEY-----"
  "PGP private key:::-----BEGIN PGP PRIVATE KEY BLOCK-----"
  "PKCS8 private key:::-----BEGIN PRIVATE KEY-----"
  "Encrypted private key:::-----BEGIN ENCRYPTED PRIVATE KEY-----"

  # ─── AWS ──────────────────────────────────────────────────────────────────
  "AWS Access Key ID:::(^|[^A-Z0-9])AKIA[0-9A-Z]{16}([^A-Z0-9]|$)"
  "AWS Session Token:::(^|[^A-Z0-9])ASIA[0-9A-Z]{16}([^A-Z0-9]|$)"

  # ─── Cloudflare ──────────────────────────────────────────────────────────
  # New scannable token formats (rolling out)
  "Cloudflare user API token:::cfu_[a-zA-Z0-9]{39,40}_[0-9a-zA-Z]{6}"
  "Cloudflare account API token:::cfa_[a-zA-Z0-9]{39,40}_[0-9a-zA-Z]{6}"
  "Cloudflare global API key:::cfk_[a-zA-Z0-9]{37}_[0-9a-zA-Z]{6}"
  "Cloudflare Origin CA key (new):::cfca_[a-zA-Z0-9]{100,}_[0-9a-zA-Z]{6}"
  "Cloudflare OAuth token:::cfoauth_[0-9a-zA-Z_-]{43,80}\.[0-9a-zA-Z_-]{43}_[0-9a-zA-Z]{6}"
  "Cloudflare delegation token:::cfdp_[A-Za-z0-9_-]{20,}"
  "Cloudflare service-linked delegation:::cfsldp_[A-Za-z0-9_-]{20,}"
  # Legacy Origin CA key
  "Cloudflare Origin CA key:::v1\.0-[A-Za-z0-9-]{100,200}"
  # Access service token client ID
  "Cloudflare Access service token:::[a-f0-9]{32}\.access"
  # R2/API key in env var assignment
  "Cloudflare credential assignment:::(CLOUDFLARE_API_KEY|CF_API_TOKEN|CF_API_KEY|R2_ACCESS_KEY|R2_SECRET_KEY)\s*=\s*['\"]?[A-Za-z0-9_-]{20,}"

  # ─── GCP / Google / Firebase ─────────────────────────────────────────────
  "GCP API key:::AIzaSy[A-Za-z0-9_-]{33}"
  "GCP service account:::\"type\"\s*:\s*\"service_account\""
  "Google OAuth access token:::ya29\.[A-Za-z0-9_-]{50,}"
  "Firebase Cloud Messaging key:::AAAA[a-zA-Z0-9_-]{100,}"

  # ─── GitHub ──────────────────────────────────────────────────────────────
  "GitHub personal access token:::ghp_[0-9A-Za-z]{36}"
  "GitHub OAuth access token:::gho_[0-9A-Za-z]{36}"
  "GitHub app token:::ghu_[0-9A-Za-z]{36}"
  "GitHub app installation token:::(ghs_[0-9A-Za-z]{36}|ghs_[0-9A-Za-z]{43})"
  "GitHub fine-grained PAT:::github_pat_[0-9A-Za-z_]{22,}"
  "GitHub refresh token:::ghr_[0-9A-Za-z]{36}"

  # ─── GitLab ──────────────────────────────────────────────────────────────
  "GitLab personal access token:::glpat-[0-9A-Za-z_-]{20}"
  "GitLab pipeline trigger token:::glptt-[0-9a-f]{40}"
  "GitLab runner auth token:::glrt-[0-9A-Za-z_-]{20}"
  "GitLab feed token:::glft-[0-9A-Za-z_-]{20}"
  "GitLab OAuth app secret:::gloas-[0-9a-f]{64}"
  "GitLab deploy token:::gldt-[0-9A-Za-z_-]{20}"
  "GitLab SCIM token:::glsoat-[0-9A-Za-z_-]{20}"
  "GitLab CI build token:::glcbt-[0-9]{1,}[A-Za-z0-9_-]{20}"
  "GitLab K8s agent token:::glagent-[0-9A-Za-z_-]{50}"

  # ─── OpenAI ──────────────────────────────────────────────────────────────
  "OpenAI project key:::sk-proj-[A-Za-z0-9_-]{20,180}"
  "OpenAI service account key:::sk-svcacct-[A-Za-z0-9_-]{20,180}"
  "OpenAI admin key:::sk-admin-[A-Za-z0-9_-]{20,180}"
  "OpenAI legacy key:::sk-[A-Za-z0-9]{48}"

  # ─── Anthropic ───────────────────────────────────────────────────────────
  "Anthropic API key:::sk-ant-api0[0-9]-[A-Za-z0-9_-]{20,120}"

  # ─── Other AI providers ─────────────────────────────────────────────────
  "Hugging Face token:::hf_[A-Za-z0-9]{30,}"
  "Replicate API token:::r8_[A-Za-z0-9]{37}"
  "Groq API key:::gsk_[A-Za-z0-9]{20,70}"
  "Cursor API key:::crsr_[a-fA-F0-9]{32,}"
  "Cohere API key:::co_[A-Za-z0-9]{20,}"
  "Fireworks AI API key:::fw_[A-Za-z0-9]{20,}"
  "Perplexity API key:::pplx-[A-Za-z0-9]{20,}"

  # ─── Slack ───────────────────────────────────────────────────────────────
  "Slack bot/user token:::xoxb-[0-9]{10,}-[0-9A-Za-z]{10,}"
  "Slack user OAuth token:::xoxp-[0-9]{10,}-[0-9]{10,}-[0-9A-Za-z]{10,}"
  "Slack app-level token:::xapp-[0-9]-[A-Z0-9]+-[0-9]+-[0-9a-z]+"
  "Slack webhook:::hooks\.slack\.com/services/T[A-Z0-9]+/B[A-Z0-9]+/[A-Za-z0-9]+"
  "Slack config token:::xoxe\.xox[bp]-[0-9]+-[0-9]+-[0-9]+-[0-9a-f]+"

  # ─── Stripe ──────────────────────────────────────────────────────────────
  "Stripe live secret key:::sk_live_[0-9a-zA-Z]{24,}"
  "Stripe live restricted key:::rk_live_[0-9a-zA-Z]{24,}"
  "Stripe live publishable key:::pk_live_[0-9a-zA-Z]{24,}"

  # ─── HashiCorp ───────────────────────────────────────────────────────────
  "Terraform Cloud token:::['\"]?[a-zA-Z0-9]{14}\.atlasv1\.[a-zA-Z0-9_-]{60,}"
  "Vault service token:::hvs\.[A-Za-z0-9_-]{24,}"
  "Vault batch token:::hvb\.[A-Za-z0-9_-]{24,}"

  # ─── Package registries ─────────────────────────────────────────────────
  "npm access token:::npm_[A-Za-z0-9]{36}"
  "PyPI upload token:::pypi-AgEIcHlwaS5vcmc[A-Za-z0-9_-]{50,}"
  "RubyGems API token:::rubygems_[0-9a-f]{48}"
  "Docker PAT:::dckr_pat_[A-Za-z0-9_-]{20,}"
  "Buildkite agent token:::bkua_[A-Za-z0-9]{20,}"
  "CircleCI API token:::circleci_[A-Za-z0-9]{20,}"
  "Netlify access token:::nfp_[A-Za-z0-9]{20,}"
  "Netlify deploy token:::nft_[A-Za-z0-9]{20,}"
  "Fly.io token:::fo1_[A-Za-z0-9]{20,}"
  "Railway token:::railway_[A-Za-z0-9]{20,}"
  "Render API key:::rnd_[A-Za-z0-9]{20,}"
  "Tailscale API key:::tskey-[A-Za-z0-9-]{20,}"

  # ─── Email / messaging services ─────────────────────────────────────────
  "SendGrid API key:::SG\.[A-Za-z0-9_-]{22}\.[A-Za-z0-9_-]{43}"
  "Mailgun API key:::key-[0-9a-zA-Z]{32}"
  "Twilio API key:::SK[0-9a-fA-F]{32}"
  "Telegram bot token:::[0-9]{5,16}:A[a-zA-Z0-9_-]{34}"

  # ─── DigitalOcean ────────────────────────────────────────────────────────
  "DigitalOcean token:::do[opr]_v1_[a-f0-9]{64}"

  # ─── Heroku ───────────────��──────────────────────────────────────────────
  "Heroku API key:::(HEROKU_API_KEY|HEROKU_TOKEN)\s*[=:]\s*['\"]?[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}"

  # ─── PlanetScale ─────────────────────────────────────────────────────────
  "PlanetScale credential:::pscale_(tkn|oauth|pw)_[a-zA-Z0-9_.=-]{32,64}"

  # ─── Doppler ─────────────────────────────────────────────────────────────
  "Doppler token:::dp\.(st|pt|ct|sa|scim|audit)\.[a-zA-Z0-9._-]{20,}"
  "1Password service account:::ops_[A-Za-z0-9]{20,}"
  "Age encryption key:::AGE-SECRET-KEY-1[A-Za-z0-9]{58}"

  # ─── Grafana ─────────────────────────────────────────────────────────────
  "Grafana service account token:::glsa_[A-Za-z0-9]{32}_[A-Fa-f0-9]{8}"
  "Grafana Cloud API token:::glc_[A-Za-z0-9+/]{32,}"

  # ─── Sentry ──────────────────────────────────────────────────────────────
  "Sentry user token:::sntryu_[a-f0-9]{64}"
  "Sentry org token:::sntrys_[a-zA-Z0-9+/]{60,}"
  "Sentry DSN:::https://[a-f0-9]{32}@[a-z0-9.-]*sentry\.io/[0-9]+"
  "Pinecone API key:::pc-[A-Za-z0-9]{20,}"

  # ─── Supabase ────────────────────────────────────────────────────────────
  "Supabase PAT:::sbp_[a-zA-Z0-9]{40,}"
  "Supabase secret key:::sb_secret_[a-zA-Z0-9_-]{20,}"

  # ─── Pulumi ──────────────────────────────────────────────────────────────
  "Pulumi access token:::pul-[a-f0-9]{40}"

  # ─── Postman ─────────────────────────────────────────────────────────────
  "Postman API key:::PMAK-[a-f0-9]{24}-[a-f0-9]{34}"

  # ─── Linear ──────────────────────────────────────────────────────────────
  "Linear API key:::lin_api_[A-Za-z0-9]{40}"

  # ─── Shopify ─────────────────────────────────────────────────────────────
  "Shopify access token:::shpat_[0-9a-fA-F]{32}"
  "Shopify shared secret:::shpss_[0-9a-fA-F]{32}"
  "Notion API key:::ntn_[A-Za-z0-9]{20,}"
  "Notion integration token:::secret_[A-Za-z0-9]{43}"
  "Figma personal access token:::figd_[A-Za-z0-9_-]{20,}"
  "Contentful PAT:::CFPAT-[A-Za-z0-9_-]{20,}"
  "Airtable PAT:::pat[A-Za-z0-9]{14}\.[a-f0-9]{64}"
  "Datadog API key:::dd-[A-Za-z0-9]{30,}"

  # ─── Discord ─────────────────────────────────────────────────────────────
  "Discord bot token:::[MN][A-Za-z0-9]{23,}\.[A-Za-z0-9_-]{6,}\.[A-Za-z0-9_-]{27,}"
  "Discord webhook:::discord(app)?\.com/api/webhooks/[0-9]+/[A-Za-z0-9_-]+"

  # ─── Azure ───────────────────────────────────────────────────────────────
  "Azure storage account key:::AccountKey=[a-zA-Z0-9+/]{86}=="
  "Azure AD client secret:::[a-zA-Z0-9_.~]{3}[0-9]Q~[a-zA-Z0-9_.~-]{31,34}"
  "Azure connection string:::DefaultEndpointsProtocol=https?;AccountName=[^;]+;AccountKey="

  # ─── Twitch ──────────────────────────────────────────────────────────────
  "Twitch OAuth token:::oauth:[a-z0-9]{30}"

  # ─── Twitter/X ───────────────────────────────────────────────────────────
  "Twitter bearer token:::AAAAAAAAAAAAAAAAAAAAAA[a-zA-Z0-9%]{80,100}"

  # ─── Database connection strings ─────────────────────────────────────────
  "Database connection string:::(mysql|postgres|postgresql|mongodb|mongodb\+srv|redis|amqp|amqps)://[^:]+:[^@]+@[^/\s]+"

  # ─── Password in URL ────────────────────────────────────────────────────
  "Password in URL:::https?://[^:]+:[^@]+@[^/\s]+"

  # ─── Generic high-entropy secrets (env var assignments) ──────────────────
  "Hardcoded password:::(PASSWORD|PASSWD|SECRET|TOKEN|API_KEY|APIKEY|ACCESS_KEY|PRIVATE_KEY)\s*[=:]\s*['\"]?[A-Za-z0-9/+=_-]{20,}['\"]?"
)

# ── Filename patterns that indicate secrets ──
SECRET_FILENAMES=(
  "*.pem"
  "*.p12"
  "*.pfx"
  "*.key"
  "*.keystore"
  "*.jks"
  "id_rsa"
  "id_dsa"
  "id_ecdsa"
  "id_ed25519"
  ".env"
  ".env.local"
  ".env.production"
  ".env.staging"
  ".env.development"
  "credentials.json"
  "service-account*.json"
  ".htpasswd"
  ".netrc"
  ".npmrc"
  ".pypirc"
)

# ── Files to skip (test fixtures, lock files, known safe) ──
SKIP_FILE_PATTERNS=(
  "*.lock"
  "package-lock.json"
  "yarn.lock"
  "pnpm-lock.yaml"
  "Gemfile.lock"
  "go.sum"
  "*.min.js"
  "*.min.css"
  "*.map"
  "*.snap"
  "vendor/"
  "node_modules/"
  "test/fixtures/"
  "tests/fixtures/"
  "spec/fixtures/"
  "__fixtures__/"
  ".env.example"
  ".env.sample"
  ".env.template"
)

# ─── Helper: check if a path should be skipped ──────────────────────────────
should_skip() {
  local filepath="$1"
  for pattern in "${SKIP_FILE_PATTERNS[@]}"; do
    case "${pattern}" in
      */  ) # Directory prefix
        if [[ "${filepath}" == *"${pattern}"* ]]; then
          return 0
        fi
        ;;
      *.* ) # Extension or filename glob
        local basename
        basename="${filepath##*/}"
        # shellcheck disable=SC2254
        case "${basename}" in
          ${pattern}) return 0 ;;
        esac
        # Also check the full path for exact matches
        # shellcheck disable=SC2254
        case "${filepath}" in
          ${pattern}) return 0 ;;
        esac
        ;;
    esac
  done
  return 1
}

# ─── Helper: check if a line is allowlisted ─────────────────────────────────
# Reads .secret-detection-allowlist from the repo (one regex per line)
ALLOWLIST_LOADED=false
ALLOWLIST_PATTERNS=()

load_allowlist() {
  local sha="$1"
  if ${ALLOWLIST_LOADED}; then
    return
  fi
  ALLOWLIST_LOADED=true
  local content
  content=$(git show "${sha}:.secret-detection-allowlist" 2>/dev/null || printf '')
  if [[ -n "${content}" ]]; then
    while IFS= read -r line; do
      # Skip empty lines and comments
      [[ -z "${line}" || "${line}" == \#* ]] && continue
      ALLOWLIST_PATTERNS+=("${line}")
    done <<< "${content}"
  fi
}

is_allowlisted() {
  local text="$1"
  for pattern in "${ALLOWLIST_PATTERNS[@]}"; do
    if printf '%s' "${text}" | grep -qE -e "${pattern}" 2>/dev/null; then
      return 0
    fi
  done
  return 1
}

# ─── Helper: resolve the effective base SHA for a push ───────────────────────
# For existing branches, old_sha is the correct base. For new branches
# (old_sha = 0000...0), we diff against the merge-base with the default
# branch so we only scan the new commits, not the entire tree.
resolve_base() {
  local old="$1" new="$2"
  if [[ "${old}" != "${ZERO_SHA}" ]]; then
    printf '%s' "${old}"
    return
  fi
  # New branch: try merge-base with HEAD (default branch on bare repos)
  local base
  base=$(git merge-base HEAD "${new}" 2>/dev/null || printf '')
  if [[ -n "${base}" ]]; then
    printf '%s' "${base}"
    return
  fi
  # Truly new repo (first push ever): use empty tree SHA
  printf '%s' "${EMPTY_TREE}"
}

# ─── Main loop ──────────────��───────────────────────────────────────────────
while read -r old_sha new_sha ref; do
  # Skip deletions
  if [[ "${new_sha}" == "${ZERO_SHA}" ]]; then
    continue
  fi

  # Load allowlist from the new commit
  load_allowlist "${new_sha}"

  # Resolve effective base for diffing
  BASE_SHA=$(resolve_base "${old_sha}" "${new_sha}")

  # ── Check filenames ──
  FILES=$(git diff --diff-filter=ACR --name-only "${BASE_SHA}" "${new_sha}" 2>/dev/null)

  BLOCKED_FILENAMES=()
  while IFS= read -r filepath; do
    [[ -z "${filepath}" ]] && continue
    local_basename="${filepath##*/}"
    for secret_file in "${SECRET_FILENAMES[@]}"; do
      case "${secret_file}" in
        *.* )
          # shellcheck disable=SC2254
          case "${local_basename}" in
            ${secret_file}) BLOCKED_FILENAMES+=("${filepath} (matches ${secret_file})") ;;
          esac
          ;;
        * )
          if [[ "${local_basename}" == "${secret_file}" ]]; then
            BLOCKED_FILENAMES+=("${filepath} (matches ${secret_file})")
          fi
          ;;
      esac
    done
  done <<< "${FILES}"

  # ── Scan diff content for secret patterns ──
  # Performance: build a combined regex from all patterns and run a single
  # grep over the entire diff. Only lines that match the combined regex are
  # then checked pattern-by-pattern to determine the label. This avoids
  # forking grep once per pattern per line (94 * N forks -> 1 + M * 94).
  DIFF=$(git diff "${BASE_SHA}" "${new_sha}" 2>/dev/null)

  FOUND_SECRETS=()
  CURRENT_FILE=""

  # Build combined regex (join all pattern regexes with |)
  COMBINED_REGEX=""
  for entry in "${SECRET_PATTERNS[@]}"; do
    REGEX="${entry#*:::}"
    if [[ -z "${COMBINED_REGEX}" ]]; then
      COMBINED_REGEX="${REGEX}"
    else
      COMBINED_REGEX="${COMBINED_REGEX}|${REGEX}"
    fi
  done

  while IFS= read -r line; do
    # Track which file we're in
    if [[ "${line}" == "diff --git a/"* ]]; then
      # Extract filename: "diff --git a/foo b/foo" -> "foo"
      CURRENT_FILE="${line#diff --git a/}"
      CURRENT_FILE="${CURRENT_FILE%% b/*}"

      # ── Check for .env files in the diff headers ──
      case "${CURRENT_FILE}" in
        .env|.env.local|.env.production|.env.staging|.env.development)
          FOUND_SECRETS+=("Dotenv file committed|${CURRENT_FILE}|.env files should not be committed")
          ;;
      esac

      continue
    fi

    # Only look at added lines (start with +, but not the +++ header)
    if [[ "${line}" != "+"* || "${line}" == "+++"* ]]; then
      continue
    fi

    # Skip files in the skip list
    if [[ -n "${CURRENT_FILE}" ]] && should_skip "${CURRENT_FILE}"; then
      continue
    fi

    # Strip the leading + for matching
    CONTENT="${line:1}"

    # Skip empty or very short lines
    if [[ ${#CONTENT} -lt 8 ]]; then
      continue
    fi

    # Fast path: check if line matches ANY pattern (single grep fork)
    if ! printf '%s' "${CONTENT}" | grep -qE -e "${COMBINED_REGEX}" 2>/dev/null; then
      continue
    fi

    # Check allowlist before spending time on label identification
    if is_allowlisted "${CONTENT}"; then
      continue
    fi

    # Slow path: identify which specific pattern matched (only for hits)
    for entry in "${SECRET_PATTERNS[@]}"; do
      LABEL="${entry%%:::*}"
      REGEX="${entry#*:::}"

      if printf '%s' "${CONTENT}" | grep -qE -e "${REGEX}" 2>/dev/null; then
        # Never show the actual secret: extract match and mask for display
        MATCH=$(printf '%s' "${CONTENT}" | grep -oE -e "${REGEX}" 2>/dev/null | head -1)
        if [[ -z "${MATCH}" ]]; then
          DISPLAY="[redacted]"
        elif [[ ${#MATCH} -le 8 ]]; then
          DISPLAY="****"
        else
          DISPLAY="${MATCH:0:4}****${MATCH: -4}"
        fi

        FOUND_SECRETS+=("${LABEL}|${CURRENT_FILE}|${DISPLAY}")
        break  # One match per line is enough
      fi
    done
  done <<< "${DIFF}"

  # ── Report results ──
  TOTAL_FINDINGS=$(( ${#BLOCKED_FILENAMES[@]} + ${#FOUND_SECRETS[@]} ))

  if [[ ${TOTAL_FINDINGS} -gt 0 ]]; then
    printf '\n' >&2
    printf '  ========================================\n' >&2
    printf '  PUSH REJECTED: potential secrets detected\n' >&2
    printf '  ========================================\n' >&2
    printf '\n' >&2
    printf '  Ref: %s\n' "${ref}" >&2
    printf '\n' >&2

    if [[ ${#BLOCKED_FILENAMES[@]} -gt 0 ]]; then
      printf '  Suspicious filenames:\n' >&2
      for entry in "${BLOCKED_FILENAMES[@]}"; do
        printf '    - %s\n' "${entry}" >&2
      done
      printf '\n' >&2
    fi

    if [[ ${#FOUND_SECRETS[@]} -gt 0 ]]; then
      printf '  Secret patterns found in diff:\n' >&2
      for entry in "${FOUND_SECRETS[@]}"; do
        IFS='|' read -r label file content <<< "${entry}"
        printf '    [%s]\n' "${label}" >&2
        printf '      File: %s\n' "${file}" >&2
        printf '      Line: %s\n' "${content}" >&2
        printf '\n' >&2
      done
    fi

    printf '  What to do:\n' >&2
    printf '    1. Remove the secret from your code\n' >&2
    printf '    2. Rotate the exposed credential immediately\n' >&2
    printf '    3. Use environment variables or a secrets manager instead\n' >&2
    printf '    4. If this is a false positive, add a regex to\n' >&2
    printf '       .secret-detection-allowlist in your repo\n' >&2
    printf '\n' >&2
    printf '  Note: Removing a secret in a new commit is NOT enough.\n' >&2
    printf '  The secret remains in git history. You must rotate it.\n' >&2
    printf '  ========================================\n' >&2
    printf '\n' >&2
    EXIT_CODE=1
  fi
done

exit "${EXIT_CODE}"
