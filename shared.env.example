# ─── Shared Variables ────────────────────────────────────────────────────────
# Common values inherited by all scripts. Copy to shared.env and fill in.
#
# Scripts source this as a fallback before their own .env, so local values
# always win. This avoids duplicating the same secrets across multiple configs.
# ─────────────────────────────────────────────────────────────────────────────

GITLAB_DOMAIN="gitlab.example.com"
GITLAB_URL="https://gitlab.example.com"
GITLAB_PAT="<YOUR_GITLAB_PERSONAL_ACCESS_TOKEN>"
TZ="America/New_York"
